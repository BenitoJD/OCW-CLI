#!/usr/bin/env bash

oss_fail() {
  printf 'oss helper error: %s\n' "$*" >&2
  exit 1
}

oss_trim() {
  local value="$1"
  value="${value#"${value%%[![:space:]]*}"}"
  value="${value%"${value##*[![:space:]]}"}"
  printf '%s\n' "$value"
}

oss_unquote() {
  local value="$1"
  case "$value" in
    \"*\") value="${value#\"}"; value="${value%\"}" ;;
    \'*\') value="${value#\'}"; value="${value%\'}" ;;
  esac
  printf '%s\n' "$value"
}

oss_load_env_file() {
  local env_file="$1"
  local line key value

  [[ -f "$env_file" ]] || return 0
  while IFS= read -r line || [[ -n "$line" ]]; do
    line="$(oss_trim "$line")"
    [[ -z "$line" || "$line" == \#* ]] && continue
    case "$line" in
      export\ *) line="${line#export }" ;;
    esac
    [[ "$line" == *=* ]] || oss_fail "invalid env line in $env_file: $line"
    key="$(oss_trim "${line%%=*}")"
    value="$(oss_unquote "$(oss_trim "${line#*=}")")"
    [[ "$key" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]] || oss_fail "invalid env key in $env_file: $key"
    case "$key" in
      OPENCODE_GO_API_KEY|OPENCODE_API_KEY|CUSTOM_OCW_KEY|OCW_BRIDGE_KEY|PROXY_API_KEY|LITELLM_MASTER_KEY)
        export "$key=$value"
        ;;
      *)
        oss_fail "unsupported env key in $env_file: $key"
        ;;
    esac
  done < "$env_file"
}

oss_require_command() {
  command -v "$1" >/dev/null 2>&1 || oss_fail "required command not found: $1"
}

oss_task_path() {
  local task="$1"
  local tasks_dir="$2"

  [[ -n "$task" ]] || oss_fail "--task is required"
  if [[ -f "$task" ]]; then
    printf '%s\n' "$task"
    return
  fi
  if [[ "$task" != */* && -f "$tasks_dir/$task.md" ]]; then
    printf '%s\n' "$tasks_dir/$task.md"
    return
  fi
  oss_fail "task file not found: $task"
}

oss_task_id() {
  local task_path="$1"
  local base

  base="$(basename "$task_path")"
  printf '%s' "${base%.*}" | tr -c 'A-Za-z0-9_.-' '-'
}

oss_strip_ansi() {
  local file="$1"

  perl -0pi -e 's/\e\[[0-9;?]*[ -/]*[@-~]//g' "$file" 2>/dev/null || true
}

oss_run_opencode() {
  local opencode_bin="$1"
  local repo_dir="$2"
  local model="$3"
  local title="$4"
  local prompt_file="$5"
  local report="$6"
  local auto_approve="$7"
  local -a cmd

  cmd=("$opencode_bin" run --pure --model "$model" --title "$title")
  if [[ "$auto_approve" -eq 1 ]]; then
    cmd+=(--dangerously-skip-permissions)
  fi
  if [[ -n "$repo_dir" ]]; then
    cmd+=(--dir "$repo_dir")
  fi
  "${cmd[@]}" < "$prompt_file" > "$report"
  oss_strip_ansi "$report"
}
