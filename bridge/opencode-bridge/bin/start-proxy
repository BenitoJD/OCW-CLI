#!/usr/bin/env bash
# Start the OpenCode Go Responses proxy.
#
# Credential loading (checked in order):
#   1. opencode-go.env file in the repo root
#   2. pass-cli (if opencode-go.env contains a pass:// reference)
#   3. OPENCODE_GO_API_KEY already in shell environment
#
# Usage: bin/start-proxy
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
ENV_FILE="${SCRIPT_DIR}/opencode-go.env"

export LITELLM_MASTER_KEY="${LITELLM_MASTER_KEY:-sk-local-codex-bridge}"
export PROXY_API_KEY="${PROXY_API_KEY:-$LITELLM_MASTER_KEY}"
export PROXY_PORT="${PROXY_PORT:-4000}"
export PROXY_STATE_DB="${PROXY_STATE_DB:-/tmp/opencode_responses_proxy_state.sqlite3}"
export FORCE_SINGLE_TOOL_INSTRUCTIONS="${FORCE_SINGLE_TOOL_INSTRUCTIONS:-0}"
export FALLBACK_MODEL_MAP_JSON="${FALLBACK_MODEL_MAP_JSON:-{\"deepseek-v4-pro\":[\"kimi-k2.6\",\"deepseek-v4-flash\"],\"kimi-k2.6\":[\"deepseek-v4-pro\"],\"deepseek-v4-flash\":[\"kimi-k2.6\"]}}"

# Already running? Skip.
if curl -s --max-time 2 "http://127.0.0.1:${PROXY_PORT}/health" \
     -H "Authorization: Bearer ${LITELLM_MASTER_KEY}" > /dev/null 2>&1; then
    echo "Bridge already running on :${PROXY_PORT}" >&2
    exit 0
fi

echo "Starting OpenCode Bridge on port ${PROXY_PORT}..." >&2

if [ -f "$ENV_FILE" ] && grep -q '^OPENCODE_GO_API_KEY=' "$ENV_FILE" 2>/dev/null; then
    echo "Using credentials from opencode-go.env" >&2
    set -a
    source "$ENV_FILE"
    set +a
    exec python3 "${SCRIPT_DIR}/bridge.py"
else
    echo "Using OPENCODE_GO_API_KEY from environment" >&2
    exec python3 "${SCRIPT_DIR}/bridge.py"
fi
